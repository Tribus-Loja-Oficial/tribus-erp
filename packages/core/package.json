{
  "name": "@tribus-erp/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --reporter=json --outputFile=.vitest-coverage.json"
  },
  "dependencies": {
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.26.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
