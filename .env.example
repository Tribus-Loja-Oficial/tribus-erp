# ─── Tribus ERP — API (Wrangler / Worker) ─────────────────────────────────
# wrangler secret put ERP_INTERNAL_SECRET
# wrangler secret put CDS_JWT_SECRET
ENVIRONMENT=development
ERP_INTERNAL_SECRET=change-me-min-32-chars-please-secure
CDS_JWT_SECRET=change-me-min-32-chars-please-secure
CDS_JWT_ISSUER=tribus-cds
CDS_JWT_AUDIENCE=tribus-platform
# CDS_API_URL=https://cds.example.com

# ─── Tribus ERP — Web (Next.js) ───────────────────────────────────────────
ERP_API_URL=http://127.0.0.1:8787
ERP_API_INTERNAL_SECRET=change-me-min-32-chars-please-secure
AUTH_SECRET=generate-with-openssl-rand-base64-32
ADMIN_EMAIL=admin@tribus.com.br
ADMIN_PASSWORD=change-me-strong-password
NEXT_PUBLIC_APP_URL=http://localhost:3000
